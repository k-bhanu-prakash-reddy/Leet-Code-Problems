class Solution {
    public int[] shuffle(int[] nums, int n) {
        int[] array=new int[2*n];
        
        for(int i=0;i<n;i++){
            array[2*i]=nums[i]; // array[0]=nums[0] upto array[2n]=array[2n]
            array[2*i+1]=nums[i+n];// array[1]=nums[3]
             }
             return array;
    }
}
