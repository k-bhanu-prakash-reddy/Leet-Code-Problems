class Solution:
    def validPalindrome(self, s: str) -> bool:
        left = 0
        right = len(s)-1
        while left < right :
            if s[left] != s[right] :
                l1 = left +1
                l2 = right
                while l1 < l2 and s[l1] == s[l2] :
                    l1 +=1
                    l2 -=1
                if l1 >= l2 :
                    return True
                l1 = left
                l2 = right-1
                while l1 < l2 and s[l1] == s[l2] :
                    l1 +=1
                    l2 -=1
                
                return l1>=l2
            left +=1
            right -=1
        return True            
